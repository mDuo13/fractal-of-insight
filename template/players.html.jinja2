{% extends "base.html.jinja2" %}

{% block subtitle %}Players - {% endblock %}

{% block body %}
<nav id="main-nav">
    <a class="nav-item" href="/">⌂ Home</a>
    <b class="nav-item">↓ Players</b>
    <a class="nav-item" href="/deck/">→ Decks</a>
    <a class="nav-item" href="/champion/">→ Champions</a>
    <a class="nav-item" href="/card/">→ Cards</a>
    <a class="nav-item" href="/achievement/">→ Achievements</a>
</nav>

<section id="player-list">
    <h1>Grand Archive Players</h1>
    <input class="smartsearch" id="player-search" placeholder="Search" />
    <button class="reset-button" data-target="#player-list .pprofile" title="Reset search" onclick="reset_player_search()">❌</button>
    <button id="prev-player-btn" class="player prevnext" disabled="disabled" onclick="prev_player_page()">« Prev</button>
    <button id="next-player-btn" class="player prevnext" onclick="next_player_page()">Next »</button>
    <div class="player-grid" data-start="0">
    {% for p in players %}
        {%- if loop.index0 < 40 -%}
        <div class="pprofile" data-name="{{p.username}}" data-eventcount="{{p.events|length}}" data-omniid="{{p.id}}">
            <a href="/player/{{p.id}}.html">
                <span class="p-name">{{p}}</span>
                <span class="p-avatar">
                {% if p.most_played_element() %}
                    <img src="/static/icon/icon-{{p.most_played_element()|slugify}}.png" alt="{{p.most_played_element()}}" loading="lazy" />
                {% endif %}
                {% if p.most_played_champ() %}
                    <img src="/static/icon/icon-{{p.most_played_champ()|slugify}}.png" alt="{{p.most_played_champ()}}" loading="lazy" />
                {% endif %}
                    <span class="p-region">{{macros.flag(p.region)}}</span>
                </span>
            </a>
            <p class="events-recorded">Events recorded:
                <span class="event-count">{{p.events|length}}</span>
            </p>
            {% if p.events|length %}
            {% set e = events[p.events[0].evt_id] %}
            <p class="last-seen">Last seen:
                <a href="/{{e.season}}/{{e.id}}.html">{{e.name}}</a>
            </p>
            {% endif %}
        </div>
    {%- endif -%}
    {% endfor %}
    </div>
</section>

<!-- Full player data JSON -->
<script>
const playerdata = {{players_json|safe}}
</script>
{% endblock %}
